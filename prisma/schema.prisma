generator client {
  provider = "prisma-client-js"
}

datasource db {
  // LOCAL DEV: SQLite (sem instalação necessária)
  // PRODUÇÃO:  troque para "postgresql" e atualize DATABASE_URL
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

// SQLite não suporta enums nativos — usamos String com valores fixos

// ──────────────────────────────────────────────
// User
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER")   // USER | CREATOR | ADMIN
  plan          String    @default("FREE")   // FREE | PRO | CREATOR
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  prompts        Prompt[]
  favorites      Favorite[]
  purchases      Purchase[]
  subscriptions  Subscription[]
  reviews        Review[]
  copies         PromptCopy[]
  creatorProfile CreatorProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Category
// ──────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())

  prompts Prompt[]
}

// ──────────────────────────────────────────────
// Prompt
// ──────────────────────────────────────────────

model Prompt {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String
  type            String   // IMAGE | VIDEO | TEXT | PACK
  categoryId      String
  creatorId       String
  promptPt        String
  promptEn        String?
  negativePrompt  String?
  instructions    String?
  recommendedTool String
  aspectRatio     String?  @default("1:1")
  tags            String   @default("[]")  // JSON array string ex: '["anime","viral"]'
  price           Float    @default(0)
  isFree          Boolean  @default(false)
  isPremium       Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  status          String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  previewImage    String?
  previewVideo    String?
  copiesCount     Int      @default(0)
  favoritesCount  Int      @default(0)
  salesCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category  Category     @relation(fields: [categoryId], references: [id])
  creator   User         @relation(fields: [creatorId], references: [id])
  favorites Favorite[]
  purchases Purchase[]
  reviews   Review[]
  copies    PromptCopy[]
}

// ──────────────────────────────────────────────
// Favorite
// ──────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
}

// ──────────────────────────────────────────────
// Purchase
// ──────────────────────────────────────────────

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  amount    Float
  status    String   @default("PENDING")  // PENDING | COMPLETED | REFUNDED
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  prompt Prompt @relation(fields: [promptId], references: [id])
}

// ──────────────────────────────────────────────
// Subscription
// ──────────────────────────────────────────────

model Subscription {
  id        String    @id @default(cuid())
  userId    String
  plan      String
  status    String    @default("ACTIVE")  // ACTIVE | CANCELLED | EXPIRED
  startedAt DateTime  @default(now())
  endsAt    DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ──────────────────────────────────────────────
// Review
// ──────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  prompt Prompt @relation(fields: [promptId], references: [id])

  @@unique([userId, promptId])
}

// ──────────────────────────────────────────────
// CreatorProfile
// ──────────────────────────────────────────────

model CreatorProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  avatar       String?
  socialLinks  String?  // JSON string
  totalSales   Int      @default(0)
  totalPrompts Int      @default(0)
  rating       Float    @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ──────────────────────────────────────────────
// PromptCopy
// ──────────────────────────────────────────────

model PromptCopy {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  prompt Prompt @relation(fields: [promptId], references: [id])
}
