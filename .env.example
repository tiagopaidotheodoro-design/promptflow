# Banco de dados (PostgreSQL)
# Exemplo Neon.tech: postgresql://user:password@host/dbname?sslmode=require
# Exemplo local:     postgresql://user:password@localhost:5432/prompthub
DATABASE_URL=

# NextAuth / Auth.js
NEXTAUTH_SECRET=           # gere com: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# OAuth Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pagamentos (configurar depois)
MERCADO_PAGO_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# URL pública da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upload de imagens (opcional - Uploadthing ou similar)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
